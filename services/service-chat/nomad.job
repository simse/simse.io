job "simse.io/service-chat-[[ env "ENV" ]]" {
  region = "global"
  datacenters = ["dc1"]
  type        = "service"

  meta {
    version = "3"
  }

  group "service-chat" {
    count = 2

    network {
      port "http" {
        to = 4040
        host_network = "private"
      }
    }

    task "service-chat" {
      driver = "docker"
      
      config {
        image = "[[ env "DOCKER_IMAGE" ]]"
        ports = ["http"]
        force_pull = true
      }

      env {
        ENV = "[[ env "ENV" ]]"
      }

      template {
        data = <<EOF
        {{with secret "secrets/data/simse.io/service-chat/[[ env "ENV" ]]"}}
          DATABASE_URL = "{{.Data.data.DATABASE_URL}}"
          OPENAI_API_KEY = "{{.Data.data.OPENAI_API_KEY}}"
          DATA_SERVICE_URL = "{{.Data.data.DATA_SERVICE_URL}}"
        {{end}}
        EOF
        destination = "env"
        env = true
      }

      service {
        port = "http"
	      name = "simse-io-service-chat-[[ env "ENV" ]]"

        tags = [
          "traefik.enable=true",
          "traefik.http.routers.simse-chat-[[ env "ENV" ]].rule=Host(`simse-io-service-chat-[[ env "ENV" ]].sorensen.cloud`)",
          "traefik.http.routers.simse-chat-[[ env "ENV" ]].tls.certresolver=sample",
        ]

        check {
          type     = "http"
          path     = "/health"
          interval = "10s"
          timeout  = "2s"
        }
      }

      resources {
        cpu    = 500
        memory = 512
      }

      vault {
        policies = ["simse-io-[[ env "ENV" ]]"]
        env = false
      }
    }
  }
}